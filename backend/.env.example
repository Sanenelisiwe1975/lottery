# ── Blockchain ────────────────────────────────────────────────────────────────
# WebSocket RPC (wss://) is required for reliable event listening.
# Get one from Alchemy (https://alchemy.com) or Infura (https://infura.io).
RPC_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# A wallet with ETH for gas – this is the keeper/bot wallet that auto-triggers
# draws and processes rounds. Does NOT need to be the contract owner.
KEEPER_PRIVATE_KEY=0xYOUR_KEEPER_WALLET_PRIVATE_KEY

# Deployed contract address (from `npm run deploy:sep` in the lottery/ folder)
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# Chain ID: 11155111 (Sepolia) | 137 (Polygon) | 31337 (Hardhat localhost)
CHAIN_ID=11155111

# Server
PORT=4000

# Frontend origin for CORS (add more as comma-separated if needed)
FRONTEND_URL=http://localhost:3000

# ── Hybrid Web2 ────────────────────────────────────────────────────────────────

# Secret used to AES-256-GCM encrypt user private keys in the DB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY_ENCRYPTION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# JWT signing secrets
JWT_SECRET=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_STRING
JWT_EXPIRY=24h

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# How many ticket credits a user gets per $1 spent (default: 1)
CREDITS_PER_DOLLAR=1

# Ticket price in ETH — used to convert prize winnings back to credits
TICKET_PRICE_ETH=0.01

# Flutterwave — mobile money / African payments (flutterwave.com)
FLW_PUBLIC_KEY=FLWPUBK_TEST-...
FLW_SECRET_KEY=FLWSECK_TEST-...
FLW_WEBHOOK_SECRET=any_random_string_you_set_in_flutterwave_dashboard
