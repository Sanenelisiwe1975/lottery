# ── Blockchain ────────────────────────────────────────────────────────────────
# WebSocket RPC (wss://) is required for reliable event listening.
# Get one from Alchemy (https://alchemy.com) or Infura (https://infura.io).
RPC_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# A wallet with ETH for gas – this is the keeper/bot wallet that auto-triggers
# draws and processes rounds. Does NOT need to be the contract owner.
KEEPER_PRIVATE_KEY=0xYOUR_KEEPER_WALLET_PRIVATE_KEY

# Deployed contract address (from `npm run deploy:sep` in the lottery/ folder)
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# Chain ID: 11155111 (Sepolia) | 137 (Polygon) | 31337 (Hardhat localhost)
CHAIN_ID=11155111

# Server
PORT=4000

# Frontend origin for CORS (add more as comma-separated if needed)
FRONTEND_URL=http://localhost:3000
