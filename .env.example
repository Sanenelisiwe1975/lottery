# ────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ────────────────────────────────────────────────────────────────

# Your wallet private key (deployer). Must have ETH/MATIC for gas.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC endpoints (Alchemy / Infura / QuickNode / etc.)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Etherscan / Polygonscan for contract verification
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Optional – for gas cost reporting
REPORT_GAS=false
COINMARKETCAP_API_KEY=YOUR_CMC_KEY

# ── Chainlink VRF Subscription ───────────────────────────────────
# Create a subscription at https://vrf.chain.link and fund it with LINK.
VRF_SUBSCRIPTION_ID=YOUR_SUBSCRIPTION_ID

# ── Network-specific VRF parameters ──────────────────────────────
#
#  Ethereum Sepolia (testnet)
#    Coordinator : 0x8103B0A8A00be2DDC778e6e7eaa21791Cd364625
#    Key hash    : 0x474e34a077df58807dbe9c96d3c009b23b3c6d0cce433e59bbf5b34f823bc56c
#
#  Polygon Mainnet
#    Coordinator : 0xAE975071Be8F8eE67addBC1A82488F1C24858067
#    Key hash    : 0x6e099d640cde6de9d40ac749b4b594126b0169747122711109c9985d47751f93
#
#  Full list: https://docs.chain.link/vrf/v2/subscription/supported-networks
